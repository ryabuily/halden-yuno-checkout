# Yuno sandbox credentials — Dashboard → Developers → API keys.
# Copy to .env (never commit it): cp .env.example .env
YUNO_ENVIRONMENT=sandbox
YUNO_PUBLIC_API_KEY=
YUNO_PRIVATE_SECRET_KEY=
YUNO_ACCOUNT_CODE=

# Default market (the UI switches between GB / NL / AE)
YUNO_COUNTRY_CODE=GB
YUNO_CURRENCY=GBP

# Webhook verification (Dashboard → Developers → Webhooks).
# YUNO_WEBHOOK_SECRET = the HMAC client secret you set on the webhook (x-hmac-signature).
# X_API_KEY / X_SECRET_KEY = the static headers configured on the same webhook form.
# The endpoint fails closed: without YUNO_WEBHOOK_SECRET it rejects webhooks
# (set ALLOW_UNSIGNED_WEBHOOKS=true only for throwaway local tests).
YUNO_WEBHOOK_SECRET=
X_API_KEY=
X_SECRET_KEY=

# Optional: HTTPS origin used as callback_url base for redirect methods
# (auto-detected when the checkout is opened through an https tunnel like ngrok)
# YUNO_CALLBACK_BASE=

# Ports (each server climbs to the next free port if busy)
BUGGY_PORT=3071
FIXED_PORT=3072
